{
  "extends": "./tsconfig.basic.json",
  "compilerOptions": {
    "sourceMap": true,
    "baseUrl": ".",
    "rootDir": "src",
    "strict": true,
    "paths": {
      "@/*": ["./src/*"],
      "@comp/*": ["./src/components/*"],
      "@test/*": ["./src/test/*"],
      "@storage/*": ["./src/storage/*"],
      "@path/*": ["./src/path/*"]
    },
    "lib": ["esnext", "dom"],
    "typeRoots": [
      "./node_modules/@dcloudio/types",
      "./node_modules/@types",
      "./src/@types",
      "./src/components/@types"
    ]
  },
  "exclude": ["node_modules/**/*", "src/test/**/*"],
  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.tsx", "src/**/*.vue"]
}
